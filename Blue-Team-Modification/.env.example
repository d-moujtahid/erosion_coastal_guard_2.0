PORT=5000
NODE_ENV=development

# MySQL — XAMPP local OU PlanetScale cloud
DB_HOST=localhost
DB_PORT=3306
DB_NAME=erosion_coastal_guard
DB_USER=root
DB_PASSWORD=

# JWT Authentication
JWT_SECRET=
JWT_EXPIRES_IN=8h
JWT_MAX_TOKEN_AGE=8h
JWT_ISSUER=erosion-coastal-guard-api
JWT_AUDIENCE=erosion-coastal-guard-client
JWT_SECRET_MIN_LENGTH=32
JWT_INVALID_MAX_ATTEMPTS=8
JWT_INVALID_WINDOW_MS=600000
JWT_BLOCK_DURATION_MS=900000
JWT_MAX_TOKEN_LENGTH=4096

# Brute-force protection (Blue Team)
BRUTE_FORCE_WINDOW_MS=900000
BRUTE_FORCE_MAX_ATTEMPTS=6
BRUTE_FORCE_BLOCK_MS=1800000

# CORS — URL du frontend (Vercel en production)
FRONTEND_URL=http://localhost:5000

# Security hardening (Blue Team)
SECURITY_MAX_BODY_KB=256
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=300
AUTH_RATE_LIMIT_WINDOW_MS=600000
AUTH_RATE_LIMIT_MAX_REQUESTS=20
SLOW_DOWN_WINDOW_MS=900000
SLOW_DOWN_AFTER=120
SLOW_DOWN_DELAY_MS=250
